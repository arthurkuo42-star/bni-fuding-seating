# ========================================
# bni-fuding-seating · Railway 環境變數範本
# ========================================
# 注意：本系統與富鼎主網站（bni-kpi）獨立運作，變數命名也不同：
#   - 這裡是 JSONBIN_KEY / JSONBIN_BIN
#   - 主系統是 JSONBIN_MASTER_KEY / JSONBIN_BIN_ID
# 兩邊共用同一個 JSONBin 帳號的 Master Key（regenerate 時兩邊都要改）

# ── JSONBin ──
# JSONBin.io 帳號的 Master Key
JSONBIN_KEY=your_jsonbin_master_key_here
# 座位系統專屬 bin（名稱 "BNI seat"）
JSONBIN_BIN=69d750fe36566621a893329f

# ── 伺服器 ──
# Railway 會自動給 PORT，本機開發才需要指定
PORT=3000
