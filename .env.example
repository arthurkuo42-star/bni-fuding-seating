# ========================================
# bni-speaker-tracker-proxy · Railway 環境變數範本
# ========================================
# ⚠️ 本 service 已被 bni-kpi 完全取代，預計廢棄。
#    保留此檔供歷史參考或未來回滾使用。

# ── JSONBin ──
# JSONBin.io 帳號的 Master Key
JSONBIN_MASTER_KEY=your_jsonbin_master_key_here
# Bin ID（歷史上這裡指向 bni-coffee bin，與 bni-kpi 同一顆）
JSONBIN_BIN_ID=69e0e9fcaaba88219706e410

# ── 認證 ──
# 寫入 PIN：PUT /api/data 時需帶 X-Write-PIN header
WRITE_PIN=your_write_pin

# ── CORS 白名單（逗號分隔，不設則允許全部）──
ALLOWED_ORIGINS=https://arthurkuo42-star.github.io

# ── 伺服器 ──
# Railway 會自動給 PORT
PORT=3000
